// Polymarket HQ - Dashboard database schema

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Events from Gamma API (screener)
model ScreenerEvent {
  id           String   @id @default(uuid()) @map("id")
  externalId   String   @unique @map("external_id") // Gamma market id
  slug         String   @map("slug")
  parentEventSlug String? @map("parent_event_slug") // Parent event slug for child markets; use for Polymarket link
  title        String   @map("title")
  description  String?  @db.Text @map("description")
  image        String?  @map("image")
  icon         String?  @map("icon")
  volume       Float    @default(0) @map("volume")
  liquidity    Float    @default(0) @map("liquidity")
  endDate      DateTime? @map("end_date")
  createdAt    DateTime? @map("created_at") // Gamma API: market creation date
  active       Boolean  @default(true) @map("active")
  closed       Boolean  @default(false) @map("closed")
  restricted   Boolean  @default(false) @map("restricted")
  probabilityYes Float? @map("probability_yes") // From market outcomePrices
  probabilityNo  Float? @map("probability_no")
  appraisedYes   Float? @map("appraised_yes") // AI appraisal
  appraisedNo    Float? @map("appraised_no")
  lastAppraised DateTime? @map("last_appraised")
  lastThinkAppraisedAt         DateTime? @map("last_think_appraised_at") // When think appraisal was last performed
  lastThinkAppraisalDurationSeconds Int?  @map("last_think_appraisal_duration_seconds")
  lastReappraisedAt            DateTime? @map("last_reappraised_at") // When reappraisal was last performed
  lastReappraisalDurationSeconds Int?    @map("last_reappraisal_duration_seconds")
  yev                Float? @map("yev") // Yes Expected Value = appraisedYes / quotedYes
  nev                Float? @map("nev") // No Expected Value = appraisedNo / quotedNo
  yesParoi           Float? @map("yes_paroi") // Stored during ingest; UI always calculates fresh
  noParoi            Float? @map("no_paroi") // Stored during ingest; UI always calculates fresh
  appraisalExplanation String? @db.Text @map("appraisal_explanation") // Explanation with sources
  appraisalRaw       Json?    @map("appraisal_raw") // Full OpenAI appraisal API response
  raw           Json?    @map("raw") // Full Gamma API payload
  syncedAt      DateTime @default(now()) @map("synced_at")
  label         String?  @map("label") // "opportunity" | "unknowable" | "well_priced" | null (null = discovery)
  labelUpdatedAt DateTime? @map("label_updated_at") // When label was last set (for sorting evaluating by recency)
  note          String?  @db.Text @map("note") // User note; included in appraisal prompts
  noteUpdatedAt DateTime? @map("note_updated_at") // When note was last saved
  tags          Json?    @map("tags") // Gamma API /markets/{id}/tags (array of {id, label, slug, ...})
  yesId         String?  @map("yes_id") // First clobTokenId (Yes outcome)
  noId          String?  @map("no_id")  // Second clobTokenId (No outcome)
  yesSpread     Float?   @map("yes_spread") // Ask-bid spread for Yes token (for ROI/PAROI buy price)
  noSpread      Float?   @map("no_spread")  // Ask-bid spread for No token
  traderAppraisedYes Float? @map("trader_appraised_yes") // Trader's manual probability of YES (0-1) for Kelly
  kellyPosition String?  @map("kelly_position") // "yes" | "no" - which side you're entering (default yes)
  kellyC        Float?   @map("kelly_c") // Kelly scaling factor (fractional Kelly = full Kelly / c)
  kellyCriterion Float?  @map("kelly_criterion") // Calculated Kelly criterion (fractional), displayed as %
  rulesAnalysis  String? @db.Text @map("rules_analysis") // AI analysis of resolution rules (ambiguities, edge cases)
  rulesAnalysisAt DateTime? @map("rules_analysis_at") // When rules were last analyzed
  deletedAt      DateTime? @map("deleted_at") // Soft delete; null = active

  @@index([syncedAt])
  @@index([deletedAt])
  @@index([label])
  @@index([volume])
  @@map("screener_events")
}

// Tags from Gamma API (GET https://gamma-api.polymarket.com/tags)
model GammaTag {
  id                 String   @id @map("id") // Gamma API tag id
  label              String   @map("label")
  slug               String   @map("slug")
  requiresTranslation Boolean @default(false) @map("requires_translation")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  preferences ScreenerTagPreference[]
  exclusions   ScreenerTagExclusion[]

  @@map("gamma_tags")
}

// Selected tag IDs for screener refresh (user preferences)
model ScreenerTagPreference {
  id        String   @id @default(uuid()) @map("id")
  tagId     String   @map("tag_id") // References GammaTag.id
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  tag GammaTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([tagId])
  @@map("screener_tag_preferences")
}

// Excluded tag IDs for screener refresh (markets with these tags are skipped)
model ScreenerTagExclusion {
  id        String   @id @default(uuid()) @map("id")
  tagId     String   @map("tag_id") // References GammaTag.id
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  tag GammaTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([tagId])
  @@map("screener_tag_exclusions")
}
// User-defined position categories (dashboard) - scoped by wallet
model PositionCategory {
  wallet    String   @map("wallet")
  id        String   @map("id") // Client-generated id (e.g. cat_xxx)
  name      String   @map("name")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  assignments PositionCategoryAssignment[]

  @@id([wallet, id])
  @@index([wallet])
  @@map("position_categories")
}

// Position-to-category assignments (asset = token/position ID)
model PositionCategoryAssignment {
  id         String   @id @default(uuid()) @map("id")
  wallet     String   @map("wallet")
  asset      String   @map("asset")
  categoryId String   @map("category_id")
  createdAt  DateTime @default(now()) @map("created_at")

  category PositionCategory @relation(fields: [wallet, categoryId], references: [wallet, id], onDelete: Cascade)

  @@unique([wallet, asset])
  @@index([wallet])
  @@map("position_category_assignments")
}


// Placeholder for future Polymarket data sync
model SyncLog {
  id         String   @id @default(uuid()) @map("id")
  source     String   @map("source") // e.g. "gamma-api", "clob-api"
  status     String   @map("status") // "success" | "failed"
  recordCount Int?    @map("record_count")
  error      String?  @map("error")
  startedAt  DateTime @default(now()) @map("started_at")
  finishedAt DateTime? @map("finished_at")

  @@index([source])
  @@index([startedAt])
  @@map("sync_logs")
}
